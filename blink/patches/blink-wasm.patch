+#ifdef __EMSCRIPTEN__
+// Like Blink(), but returns the guest exit code instead of exiting the process.
+// Used to run a forked/exec'd child machine to completion within the parent's
+// call stack (WebAssembly has no host fork). trapexit makes SysExitGroup halt
+// via kMachineExitTrap instead of calling exit(); see blink/syscall.c.
+int RunMachineUntilExit(struct Machine *m) {
+  int rc;
+  // Fork() (syscall.c) calls this NESTED, from inside the parent's own
+  // still-in-progress clone()/vfork() syscall dispatch — m->sysdepth already
+  // reflects THAT outer nesting level, and the OpSyscall frame waiting on
+  // Fork()'s return will do `unassert(--m->sysdepth >= 0)` once we return.
+  // The per-iteration reset below (copied from Blink()'s loop, correct for
+  // the single-top-level-machine case: after a signal/exit escapes Actor(m)
+  // via siglongjmp, sysdepth is a leftover mid-syscall value with no outer
+  // caller left to care) would clobber that outer nesting if left in place
+  // on our way out — so restore it right before returning.
+  int caller_sysdepth = m->sysdepth;
+  m->system->trapexit = true;
+  for (;;) {
+    if (!(rc = sigsetjmp(m->onhalt, 1))) {
+      m->canhalt = true;
+      Actor(m);
+    }
+    m->sysdepth = 0;
+    m->sigdepth = 0;
+    m->canhalt = false;
+    m->nofault = false;
+    m->insyscall = false;
+    CollectPageLocks(m);
+    CollectGarbage(m, 0);
+    if (IsMakingPath(m)) {
+      AbandonPath(m);
+    }
+    if (rc == kMachineExitTrap && m->system->exited) {
+      m->sysdepth = caller_sysdepth;
+      return m->system->exitcode & 255;
+    }
+    if (rc == kMachineFatalSystemSignal) {
+      HandleFatalSystemSignal(m, &g_siginfo);
+    }
+  }
+}
+#endif
+
 void HandleFatalSystemSignal(struct Machine *m, const siginfo_t *si) {
   int sig;
   RestoreIp(m);
