+// ── wasm process model ──────────────────────────────────────────────────────
+//
+// WebAssembly has no host fork()/execve()/wait4(). We emulate the vfork()
+// contract — which is what busybox hush (NOMMU build) and musl's posix_spawn
+// (which is what Rust's std::process::Command uses, see SysClone's
+// IsForkOrVfork check) actually call — using plain recursive C calls, since
+// vfork()'s real semantics (child temporarily shares the parent's address
+// space; parent is suspended until the child execve()s or exits) map directly
+// onto "run the child to completion, in place, before returning to the
+// parent's syscall site":
+//
+//   1. Fork() sets ax=0 (the child's view of vfork()'s return value) on the
+//      SAME Machine `m` — no new Machine/System is created, matching real
+//      vfork()'s shared address space — then runs it via RunMachineUntilExit
+//      until it calls _exit()/exit_group() (already wired through blink's
+//      existing trapexit+kMachineExitTrap mechanism — see SysExitGroup).
+//   2. If the child calls execve() first (the overwhelmingly common case),
+//      SysExecve (below) replaces `m`'s loaded program IN PLACE (wipe virtual
+//      memory, load the new ELF, reset registers to its entry point) and
+//      returns normally — the interpreter just continues fetching
+//      instructions at the new m->ip, no unwind needed. It then runs to
+//      completion and calls exit_group like any program.
+//   3. Fork() returns the synthesized child pid — OpSyscall writes it to
+//      m->ax, so the ORIGINAL vfork() call site (now resumed as the parent)
+//      sees the correct return value with m->ip already past the syscall.
+//   4. The child's exit status is stashed keyed by pid; SysWait4 (below)
+//      looks it up instead of calling a host wait4()/waitpid() that doesn't
+//      exist for these synthetic pids.
+//
+// Limitation: this does NOT support true fork() (independent, concurrently-
+// running address spaces) — only the fork-then-immediately-exec-or-exit
+// pattern. That covers every case in our guest toolset (busybox hush, the
+// `runner` binary's `sh -c`, Rust's Command). A real fork() followed by both
+// parent and child continuing to run concurrently would hang (the "parent"
+// doesn't resume until the "child" exits/execs).
+
+#define EM_MAX_CHILDREN 64
+static struct {
+  int pid;
+  int status;
+  bool used;
+} g_em_children[EM_MAX_CHILDREN];
+
+static void EmStashChildStatus(int pid, int exitcode) {
+  int i;
+  for (i = 0; i < EM_MAX_CHILDREN; ++i) {
+    if (!g_em_children[i].used) {
+      g_em_children[i].used = true;
+      g_em_children[i].pid = pid;
+      g_em_children[i].status = (exitcode & 255) << 8;  // WIFEXITED encoding
+      return;
+    }
+  }
+  LOGF("too many pending vfork children awaiting wait4()");
+}
+
+// Finds and consumes (removes) a stashed child status. wpid<=0 matches any.
+// Returns the matched pid, or -1 if none found.
+static int EmReapChildStatus(int wpid, int *out_status) {
+  int i;
+  for (i = 0; i < EM_MAX_CHILDREN; ++i) {
+    if (g_em_children[i].used &&
+        (wpid <= 0 || g_em_children[i].pid == wpid)) {
+      int found_pid = g_em_children[i].pid;
+      *out_status = g_em_children[i].status;
+      g_em_children[i].used = false;
+      return found_pid;
+    }
+  }
+  return -1;
+}
+
+// Guest fds live in [0, kMinBlinkFd); blink's own fds are >= kMinBlinkFd.
+struct EmFdSave {
+  int fildes;  // guest fd number (== host fd number in blink's model)
+  int oflags;  // blink Fd oflags, to rebuild the Fd struct
+  int slot;    // high host fd holding a dup of the original open file
+};
+
+// Snapshot the parent's fd table before running a vfork child by dup()ing each
+// open guest fd to a high slot (F_DUPFD_CLOEXEC min=kMinBlinkFd lands above the
+// guest range and skips blink's own fds), so the child's open/dup2/close for
+// redirections and pipes can be undone on resume. Returns the number of saved
+// entries.
+//
+// KNOWN LIMITATION (see the microvm-lite plan): dup2()ing fd 0/1/2 back on
+// restore rebinds those Emscripten fd slots to fresh stream objects that no
+// longer route through the worker's stdout/stderr TTY put_char capture, so in a
+// long-lived worker every command AFTER the first forking one loses its output.
+// Individual commands (fresh worker) are correct. Fixing this needs a cleaner
+// process/fd model — see the meta-discussion in the plan.
+static int EmSaveFds(struct Machine *m, struct EmFdSave *sv, int max) {
+  int n = 0;
+  struct Dll *e;
+  LOCK(&m->system->fds.lock);
+  for (e = dll_first(m->system->fds.list); e && n < max;
+       e = dll_next(m->system->fds.list, e)) {
+    struct Fd *fd = FD_CONTAINER(e);
+    if (fd->fildes < 0 || fd->fildes >= kMinBlinkFd) continue;  // skip vm fds
+    sv[n].fildes = fd->fildes;
+    sv[n].oflags = fd->oflags;
+    sv[n].slot = VfsFcntl(fd->fildes, F_DUPFD_CLOEXEC, kMinBlinkFd);
+    if (sv[n].slot == -1) {
+      LOGF("EmSaveFds: could not preserve fd %d (errno %d)", fd->fildes, errno);
+      continue;  // best effort: this fd won't be restorable, but don't abort
+    }
+    ++n;
+  }
+  UNLOCK(&m->system->fds.lock);
+  return n;
+}
+
+// Undo whatever the vfork child did to the shared fd table: tear down the
+// child's Fd list (freeing structs, closing the host fds it left in the guest
+// range), then restore each parent fd from its saved slot and rebuild the Fd
+// struct — leaving the table as it was at vfork() time.
+void EmSockOnClose(int fildes);  // defined in the M3 socket section below
+void EmDbgf(const char *fmt, ...);
+
+static void EmRestoreFds(struct Machine *m, struct EmFdSave *sv, int n) {
+  struct Dll *e, *e2;
+  int i, j;
+  LOCK(&m->system->fds.lock);
+  for (e = dll_first(m->system->fds.list); e; e = e2) {
+    struct Fd *fd = FD_CONTAINER(e);
+    e2 = dll_next(m->system->fds.list, e);
+    if (fd->fildes < 0 || fd->fildes >= kMinBlinkFd) continue;  // leave vm fds
+    dll_remove(&m->system->fds.list, e);
+    VfsClose(fd->fildes);
+    // A virtual socket the CHILD opened dies with the child's fd — clear its
+    // side-table entry so the fd number can't hijack an unrelated later fd.
+    // But if the parent owned this fd number too (it's in the saved set), the
+    // dup2 below restores the same open file, so any socket entry stays valid.
+    for (j = 0; j < n; ++j) {
+      if (sv[j].slot != -1 && sv[j].fildes == fd->fildes) break;
+    }
+    if (j == n) EmSockOnClose(fd->fildes);
+    FreeFd(fd);
+  }
+  for (i = 0; i < n; ++i) {
+    if (sv[i].slot == -1) continue;
+    VfsDup2(sv[i].slot, sv[i].fildes);  // restore the parent's open file
+    VfsClose(sv[i].slot);               // release the save slot
+    AddFd(&m->system->fds, sv[i].fildes, sv[i].oflags);
+  }
+  UNLOCK(&m->system->fds.lock);
+}
+
+static int Fork(struct Machine *m, u64 flags, u64 stack, u64 ctid) {
+  static int next_pid = 1000;
+  int child_pid, rc, nsv;
+  bool saved_vfork_child;
+  u64 saved_ip;
+  u32 saved_flags;
+  u8 saved_beg[128];   // the general register file
+  u8 saved_xmm[256];   // the vector register file (16 x 16 bytes)
+  struct EmFdSave sv[kMinBlinkFd];  // at most one entry per guest fd
+  (void)flags;
+  (void)ctid;
+  child_pid = ++next_pid;
+
+  // vfork() runs the child on the SAME Machine `m` as the parent (they share
+  // one address space, exactly as real vfork() specifies). The child mutates
+  // registers, the fd table, and — until it execve()s — the shared memory, so
+  // we snapshot everything the parent needs to resume from its vfork() call
+  // site and restore it once the child has execve()d or _exit()ed. The child's
+  // execve() runs the new program in a FRESH machine (see SysExecve) so it
+  // never clobbers this parent memory — the crucial difference from a plain
+  // in-place execve, which would destroy the shared program image.
+  nsv = EmSaveFds(m, sv, kMinBlinkFd);
+  saved_ip = m->ip;
+  saved_flags = m->flags;
+  memcpy(saved_beg, m->beg, sizeof(saved_beg));
+  memcpy(saved_xmm, m->xmm, sizeof(saved_xmm));
+  saved_vfork_child = m->em_vfork_child;
+
+  Put64(m->ax, 0);  // child's view of fork()/vfork()/clone()'s return value
+  // Raw vfork()/fork() (stack==0, e.g. busybox hush NOMMU) implicitly shares
+  // the parent's stack; musl's posix_spawn (Rust's std::process::Command)
+  // calls clone(CLONE_VM|CLONE_VFORK, explicit_stack, ...) with its own
+  // trampoline stack so the child does NOT touch the parent's stack. The full
+  // register restore below covers sp either way, but set it up for the child.
+  if (stack) {
+    Put64(m->sp, stack);
+  }
+  m->em_vfork_child = true;
+  rc = RunMachineUntilExit(m);
+  m->em_vfork_child = saved_vfork_child;
+
+  // Restore the parent's full pre-vfork() register + fd state so it resumes at
+  // its vfork() call site as if the child had run in a separate process.
+  m->ip = saved_ip;
+  m->flags = saved_flags;
+  memcpy(m->beg, saved_beg, sizeof(saved_beg));
+  memcpy(m->xmm, saved_xmm, sizeof(saved_xmm));
+  EmRestoreFds(m, sv, nsv);
+
+  EmStashChildStatus(child_pid, rc);
+  THR_LOGF("pid=%d Fork (wasm, run-to-completion) -> child_pid=%d exit=%d",
+           m->system->pid, child_pid, rc);
+  return child_pid;  // OpSyscall writes this to m->ax for the resumed parent
+}
+
+static int SysFork(struct Machine *m) {
+  return Fork(m, 0, 0, 0);
+}
+
+static int SysVfork(struct Machine *m) {
+  return Fork(m, 0, 0, 0);
+}
+
+// ── M3: virtual sockets → HTTP fetch bridge ─────────────────────────────────
+//
+// The guest's HTTP clients (musl ureq clients + busybox wget) do
+// getaddrinfo → socket → connect → write(request) → read(response) → close.
+// getaddrinfo needs no syscall support: /etc/hosts is seeded by the worker
+// with fake IPs for the virtual endpoints (the configured virtual hosts), and musl
+// consults /etc/hosts before DNS. Everything below reproduces the rest of the
+// path WITHOUT host sockets (Emscripten's socket layer is WebSocket-proxy
+// emulation — unusable for plain fetch):
+//
+//   socket()  → a MEMFS temp FILE fd (same trick as the file-backed pipes)
+//               plus a side-table entry. Request bytes written by the guest
+//               accumulate in the backing file via the NORMAL write path — no
+//               write interception at all.
+//   connect() → records the destination IP/port in the table entry.
+//   read()    → on the FIRST read of a connected socket, the accumulated
+//               request bytes are handed to JS (Module.emHttpFetch, an
+//               Asyncify suspend point), and the raw HTTP response replaces
+//               the backing file's contents with the offset rewound; that
+//               read and all later ones then proceed down the normal file
+//               path, ending in a clean EOF (= server close) when drained.
+//   close()   → frees the table entry (hooked in CloseFd, covering close,
+//               close_range, and O_CLOEXEC exec teardown).
+//
+// A response always carries "Connection: close" (the worker enforces it), so
+// clients don't pool/reuse sockets across a vfork — a socket's lifetime stays
+// inside one request, which keeps it out of the M2 fd save/restore tension.
+
+#define EM_MAX_SOCKETS 16
+
+static struct EmSock {
+  bool used;
+  bool connected;
+  bool fetched;
+  int fildes;
+  u16 port;  // network byte order, as read from the guest's sockaddr_in
+  u32 addr;  // network byte order
+} g_em_socks[EM_MAX_SOCKETS];
+
+static struct EmSock *EmSockFind(int fildes) {
+  int i;
+  for (i = 0; i < EM_MAX_SOCKETS; ++i) {
+    if (g_em_socks[i].used && g_em_socks[i].fildes == fildes) {
+      return &g_em_socks[i];
+    }
+  }
+  return 0;
+}
+
+void EmSockOnClose(int fildes) {
+  struct EmSock *s = EmSockFind(fildes);
+  if (s) memset(s, 0, sizeof(*s));
+}
+
+// Debug tap to the worker console (Module.emHttpLog → postMessage dbg).
+EM_JS(void, em_dbg, (const char *msg), {
+  if (Module.emHttpLog) Module.emHttpLog(UTF8ToString(msg));
+});
+
+void EmDbgf(const char *fmt, ...) {
+  char buf[256];
+  va_list va;
+  va_start(va, fmt);
+  vsnprintf(buf, sizeof(buf), fmt, va);
+  va_end(va);
