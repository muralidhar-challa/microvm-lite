+// ── wasm process model ──────────────────────────────────────────────────────
+//
+// WebAssembly has no host fork()/execve()/wait4(). We emulate the vfork()
+// contract — which is what busybox hush (NOMMU build) and musl's posix_spawn
+// (which is what Rust's std::process::Command uses, see SysClone's
+// IsForkOrVfork check) actually call — using plain recursive C calls, since
+// vfork()'s real semantics (child temporarily shares the parent's address
+// space; parent is suspended until the child execve()s or exits) map directly
+// onto "run the child to completion, in place, before returning to the
+// parent's syscall site":
+//
+//   1. Fork() sets ax=0 (the child's view of vfork()'s return value) on the
+//      SAME Machine `m` — no new Machine/System is created, matching real
+//      vfork()'s shared address space — then runs it via RunMachineUntilExit
+//      until it calls _exit()/exit_group() (already wired through blink's
+//      existing trapexit+kMachineExitTrap mechanism — see SysExitGroup).
+//   2. If the child calls execve() first (the overwhelmingly common case),
+//      SysExecve (below) replaces `m`'s loaded program IN PLACE (wipe virtual
+//      memory, load the new ELF, reset registers to its entry point) and
+//      returns normally — the interpreter just continues fetching
+//      instructions at the new m->ip, no unwind needed. It then runs to
+//      completion and calls exit_group like any program.
+//   3. Fork() returns the synthesized child pid — OpSyscall writes it to
+//      m->ax, so the ORIGINAL vfork() call site (now resumed as the parent)
+//      sees the correct return value with m->ip already past the syscall.
+//   4. The child's exit status is stashed keyed by pid; SysWait4 (below)
+//      looks it up instead of calling a host wait4()/waitpid() that doesn't
+//      exist for these synthetic pids.
+//
+// Limitation: this does NOT support true fork() (independent, concurrently-
+// running address spaces) — only the fork-then-immediately-exec-or-exit
+// pattern. That covers every case in our guest toolset (busybox hush, the
+// `runner` binary's `sh -c`, Rust's Command). A real fork() followed by both
+// parent and child continuing to run concurrently would hang (the "parent"
+// doesn't resume until the "child" exits/execs).
+
+#define EM_MAX_CHILDREN 64
+static struct {
+  int pid;
+  int status;
+  bool used;
+} g_em_children[EM_MAX_CHILDREN];
+
+// main() is re-invoked many times per module instance in the wasm build (one
+// top-level command == one em_main() call, see stubs.c's em_reset_getopt
+// comment for the general pattern) — this table must NOT survive between
+// them. A shell that exits without wait()ing every child it forked (common:
+// job-control bookkeeping, an already-reaped-by-shell-itself entry) leaves a
+// stale "used" slot; wpid<=0 in a LATER, unrelated command's wait4() can then
+// match that stale entry instead of its own real child, corrupting pipeline
+// synchronization in a way that only shows up after enough prior commands
+// have forked in this worker (observed: a 3rd command in one session).
+void em_reset_children(void);
+void em_reset_children(void) {
+  memset(g_em_children, 0, sizeof(g_em_children));
+#ifdef __EMSCRIPTEN__
+  MvlSchedReset();
+#endif
+}
+
+static void EmStashChildStatus(int pid, int exitcode) {
+  int i;
+  for (i = 0; i < EM_MAX_CHILDREN; ++i) {
+    if (!g_em_children[i].used) {
+      g_em_children[i].used = true;
+      g_em_children[i].pid = pid;
+      g_em_children[i].status = (exitcode & 255) << 8;  // WIFEXITED encoding
+      return;
+    }
+  }
+  LOGF("too many pending vfork children awaiting wait4()");
+}
+
+// Finds and consumes (removes) a stashed child status. wpid<=0 matches any.
+// Returns the matched pid, or -1 if none found.
+static int EmReapChildStatus(int wpid, int *out_status) {
+  int i;
+  for (i = 0; i < EM_MAX_CHILDREN; ++i) {
+    if (g_em_children[i].used &&
+        (wpid <= 0 || g_em_children[i].pid == wpid)) {
+      int found_pid = g_em_children[i].pid;
+      *out_status = g_em_children[i].status;
+      g_em_children[i].used = false;
+      return found_pid;
+    }
+  }
+  return -1;
+}
+
+// ── Guest-memory snapshot around run-to-completion fork children ─────────────
+//
+// blink's wasm Fork() runs the child on the SAME machine/guest memory as the
+// parent (run-to-completion vfork model). That is correct for the classic
+// vfork→execve pattern, but a shell's pipeline/subshell child that NEVER
+// execve()s runs the shell's own code in-process: it mutates parent heap state
+// that real fork() isolation would have copied (e.g. dash's forkchild() resets
+// the job table the parent dereferences the moment it resumes → SEGV). The
+// registers and fd table are already snapshot/restored around the child; this
+// section extends the exact same discipline to guest MEMORY, which gives the
+// parent true fork semantics for any guest (any shell) without COW machinery:
+// snapshot every mapped page before the child runs, restore after it exits.
+//
+// Wasm builds are always the non-linear page-table mode (CAN_64BIT is false),
+// so every mapped page is reachable by walking the 4-level table at s->cr3 and
+// FindHostPage() yields its backing host page.
+void EmDbgf(const char *fmt, ...);
+
+struct EmMemPage {
+  i64 virt;   // guest page address
+  u64 entry;  // leaf PTE at snapshot time
+  u8 *copy;   // 4096-byte content copy (NULL for PAGE_RSRV reservations)
+};
+struct EmMemSnap {
+  struct EmMemPage *p;
+  long n, c;
+  i64 brk;                              // parent's program break
+  struct sigaction_linux hands[64];     // parent's signal dispositions
+};
+
+static void EmSnapAdd(struct EmMemSnap *ms, i64 virt, u64 entry, u8 *host) {
+  if (ms->n == ms->c) {
+    ms->c = ms->c ? ms->c * 2 : 512;
+    ms->p = (struct EmMemPage *)realloc(ms->p, ms->c * sizeof(*ms->p));
+  }
+  ms->p[ms->n].virt = virt;
+  ms->p[ms->n].entry = entry;
+  if (host) {
+    ms->p[ms->n].copy = (u8 *)malloc(4096);
+    memcpy(ms->p[ms->n].copy, host, 4096);
+  } else {
+    ms->p[ms->n].copy = 0;
+  }
+  ms->n++;
+}
+
+// Walk every present leaf PTE, in ascending virt order (so ms->p is sorted).
+static void EmWalkLeaves(struct System *s,
+                         void (*cb)(void *arg, i64 virt, u64 entry, u8 *mi),
+                         void *arg) {
+  u64 pt4, pt3, pt2, pt1;
+  int a, b, c, d;
+  u8 *l4, *l3, *l2, *l1, *mi;
+  l4 = GetPageAddress(s, s->cr3, true);
+  for (a = 0; a < 512; ++a) {
+    pt4 = LoadPte(l4 + a * 8);
+    if (!(pt4 & PAGE_V)) continue;
+    l3 = GetPageAddress(s, pt4, false);
+    for (b = 0; b < 512; ++b) {
+      pt3 = LoadPte(l3 + b * 8);
+      if (!(pt3 & PAGE_V)) continue;
+      l2 = GetPageAddress(s, pt3, false);
+      for (c = 0; c < 512; ++c) {
+        pt2 = LoadPte(l2 + c * 8);
+        if (!(pt2 & PAGE_V)) continue;
+        l1 = GetPageAddress(s, pt2, false);
+        for (d = 0; d < 512; ++d) {
+          mi = l1 + d * 8;
+          pt1 = LoadPte(mi);
+          if (!(pt1 & PAGE_V)) continue;
+          // canonical sign extension for the top half of the address space
+          i64 virt = ((i64)((u64)a << 39 | (u64)b << 30 | (u64)c << 21 |
+                            (u64)d << 12)
+                      << 16) >>
+                     16;
+          cb(arg, virt, pt1, mi);
+        }
+      }
+    }
+  }
+}
+
+static void MvlForkLog(const char *fmt, ...) {
+  va_list ap;
+  FILE *f = fopen("/tmp/.mvlfork.log", "a");
+  if (!f) return;
+  va_start(ap, fmt);
+  vfprintf(f, fmt, ap);
+  va_end(ap);
+  fclose(f);
+}
+
+// Install ENTRY — a fully-formed leaf PTE value read from another System —
+// into DST at VIRT, creating intermediate page-table levels as needed.
+// Mirrors ReserveVirtual's intermediate-table walk (memorymalloc.c) but
+// stores a caller-supplied entry at the leaf instead of allocating fresh
+// backing memory. Caller must OR PAGE_NOOWN into entry first, so FreePage()
+// never frees memory this System doesn't own (REAL-FORK.md).
+static bool EmInstallSharedLeaf(struct System *s, i64 virt, u64 entry) {
+  u8 *mi;
+  u64 pt;
+  i64 level, ti;
+  for (pt = s->cr3, level = 39; level >= 12; level -= 9) {
+    ti = (virt >> level) & 511;
+    mi = GetPageAddress(s, pt, level == 39) + ti * 8;
+    if (level > 12) {
+      pt = LoadPte(mi);
+      if (!(pt & PAGE_V)) {
+        if ((pt = AllocatePageTable(s)) == -1) return false;
+        StorePte(mi, pt);
+      }
+      continue;
+    }
+    StorePte(mi, entry);
+    return true;
+  }
+  return false;  // unreachable: the loop above always hits level==12
+}
+
+// Real fork(): duplicate the parent's address space into the child's own
+// System, so the child's writes are genuinely private (REAL-FORK.md).
+// Reuses EmWalkLeaves, and EmSaveMemCb's proven insight below about which
+// pages can be shared vs. must be copied: read-only pages (.text and
+// friends) can never diverge without an mprotect() neither dash nor toybox
+// issues, so they're SHARED (PTE aliased, PAGE_NOOWN-tagged) rather than
+// copied — which is also what makes this safe: writing into a genuinely
+// read-only host page is a real SIGSEGV (EmSaveMemCb), so copying them by
+// reserving-writable-then-restoring-read-only was never going to work.
+struct EmCopyAsCtx {
+  struct Machine *dst;  // child machine; CopyToUser walks ITS page tables
+  long npages;          // instrumentation: pages recreated
+  long nshared;         // instrumentation: pages shared instead of copied
+  long nbytes;          // instrumentation: bytes actually copied
+  bool failed;
+};
+
+static void EmCopyAsCb(void *arg, i64 virt, u64 entry, u8 *mi) {
+  struct EmCopyAsCtx *cx = (struct EmCopyAsCtx *)arg;
+  u8 *host;
+  (void)mi;
+  if (cx->failed) return;
+  if (!(entry & PAGE_RW)) {
+    // Read-only in the parent: share the exact same backing. PAGE_NOOWN only
+    // when there IS backing to alias (PAGE_HOST): a bare anonymous
+    // reservation has none, and must not be tagged — HandlePageFault
+    // preserves every flag but PAGE_TA/PAGE_RSRV when it materializes, so a
+    // tagged reservation would become a materialized page FreePage refuses
+    // to recycle even though the child allocated (owns) it.
+    u64 tag = (entry & PAGE_HOST) ? PAGE_NOOWN : 0;
+    if (!EmInstallSharedLeaf(cx->dst->system, virt, entry | tag)) {
+      MvlForkLog("COPYFAIL share virt=%llx entry=%llx npages=%ld\n",
+                 (unsigned long long)virt, (unsigned long long)entry,
+                 cx->npages);
+      cx->failed = true;
+      return;
+    }
+    if (entry & PAGE_RSRV) {
+      cx->dst->system->memstat.reserved += 1;
+    } else {
+      cx->dst->system->memstat.committed += 1;
+    }
+    cx->dst->system->vss += 1;
+    if (!(entry & PAGE_RSRV)) cx->dst->system->rss += 1;
+    cx->npages++;
+    cx->nshared++;
+    if ((cx->npages % 64) == 1) {
+      MvlForkLog("  sharing page #%ld virt=%llx entry=%llx\n", cx->npages,
+                 (unsigned long long)virt, (unsigned long long)entry);
+    }
+    return;
+  }
+  // Writable in the parent: it CAN diverge, so it must be a private copy.
+  // Reserve WRITABLE and copy the bytes in.
+  if (ReserveVirtual(cx->dst->system, virt, 4096,
+                     PAGE_U | PAGE_RW | (entry & PAGE_XD), -1, 0, false,
+                     true) == -1) {
+    MvlForkLog("COPYFAIL reserve virt=%llx entry=%llx npages=%ld\n",
+               (unsigned long long)virt, (unsigned long long)entry, cx->npages);
+    cx->failed = true;
+    return;
+  }
+  cx->npages++;
+  if ((cx->npages % 64) == 1) {
+    MvlForkLog("  copying page #%ld virt=%llx entry=%llx\n", cx->npages,
+               (unsigned long long)virt, (unsigned long long)entry);
+  }
+  if (!(entry & PAGE_RSRV)) {
+    // Materialized in the parent: copy the bytes, which also materializes
+    // the child's page.
+    if ((host = FindHostPage(entry))) {
+      if (CopyToUser(cx->dst, virt, host, 4096) == -1) {
+        MvlForkLog("COPYFAIL copyto virt=%llx entry=%llx npages=%ld\n",
+                   (unsigned long long)virt, (unsigned long long)entry, cx->npages);
+        cx->failed = true;
+        return;
+      }
+      cx->nbytes += 4096;
+    }
+  }
+  // else: the parent holds only a reservation here, so the child keeps one
+  // too and its first touch still sees zeros — matching fork().
+}
+
+static void EmSaveMemCb(void *arg, i64 virt, u64 entry, u8 *mi) {
+  struct EmMemSnap *ms = (struct EmMemSnap *)arg;
+  (void)mi;
+  // Read-only pages (a program's .text segment, file-backed and mapped
+  // PROT_READ|PROT_EXEC at the host level, no PAGE_RW bit) can never diverge
+  // between parent and child without an mprotect() neither dash nor toybox
+  // ever does — skip snapshotting their content entirely, matching real
+  // fork() COW semantics (only writable/dirty pages ever need copying).
+  // Necessary, not just an optimization: restoring INTO a genuinely
+  // read-only host page (e.g. after a real host mmap(PROT_READ|PROT_EXEC)
+  // for the executable's file-backed .text) is an actual SIGSEGV/SIGBUS —
+  // confirmed via lldb, not a real host page.
+  if ((entry & PAGE_RSRV) || !(entry & PAGE_RW)) {
+    EmSnapAdd(ms, virt, entry, 0);
+  } else {
+    EmSnapAdd(ms, virt, entry, FindHostPage(entry));
+  }
+}
+
+static void EmSaveMem(struct Machine *m, struct EmMemSnap *ms) {
+  memset(ms, 0, sizeof(*ms));
+  ms->brk = m->system->brk;
+  memcpy(ms->hands, m->system->hands, sizeof(ms->hands));
+  EmWalkLeaves(m->system, EmSaveMemCb, ms);
+#ifdef MVL_NATIVE_DEBUG
+  fprintf(g_mvldbg, "[EmSaveMem] pages=%ld\n", ms->n);
+#endif
+}
+
+static struct EmMemPage *EmSnapFind(struct EmMemSnap *ms, i64 virt) {
+  long lo = 0, hi = ms->n - 1, mid;
+  while (lo <= hi) {
+    mid = (lo + hi) / 2;
+    if (ms->p[mid].virt < virt) lo = mid + 1;
+    else if (ms->p[mid].virt > virt) hi = mid - 1;
+    else return &ms->p[mid];
+  }
+  return 0;
+}
+
+// State carried through the restore walk: which saved pages were seen, and
+// which currently-mapped pages are child creations that must be unmapped.
+struct EmMemRestoreCtx {
+  struct EmMemSnap *ms;
+  unsigned char *seen;      // ms->n flags
+  i64 *doom;                // child-created page virts to FreeVirtual after
+  long ndoom, cdoom;
+};
+
+static void EmRestoreMemCb(void *arg, i64 virt, u64 entry, u8 *mi) {
+  struct EmMemRestoreCtx *cx = (struct EmMemRestoreCtx *)arg;
+  struct EmMemPage *sp = EmSnapFind(cx->ms, virt);
+  if (!sp) {
+    // Child-created mapping the parent never had: unmap it after the walk
+    // (FreeVirtual mutates the tables we are iterating).
+    if (cx->ndoom == cx->cdoom) {
+      cx->cdoom = cx->cdoom ? cx->cdoom * 2 : 64;
+      cx->doom = (i64 *)realloc(cx->doom, cx->cdoom * sizeof(*cx->doom));
+    }
+    cx->doom[cx->ndoom++] = virt;
+    return;
+  }
+  cx->seen[sp - cx->ms->p] = 1;
+  if (sp->copy) {
+    if (!(entry & PAGE_RSRV)) {
+      // Both materialized: restore the parent's bytes into whatever host page
+      // currently backs this virt (the child may have swapped it).
+      memcpy(FindHostPage(entry), sp->copy, 4096);
+    }
+    // saved-materialized but currently a reservation (child munmap+remap):
+    // leave the reservation; the content restore below (absent case) does not
+    // apply — accept the rare loss and log it.
+    else {
+      EmDbgf("EmRestoreMem: %" PRIx64 " became a reservation; content lost", virt);
+    }
+  } else if (sp->entry & PAGE_RSRV) {
+    // Parent had only a reservation here.
+    if (!(entry & PAGE_RSRV)) {
+      if (sp->entry & PAGE_FILE) {
+        // Lazy file page the child materialized: materialization is identical
+        // for the parent (same file, same offset), so keep it as-is.
+      } else {
+        // Anonymous reservation the child touched: parent's first touch must
+        // still see zeros.
+        memset(FindHostPage(entry), 0, 4096);
+      }
+    }
+  }
+  // else: parent had a READ-ONLY materialized page (e.g. a .text segment,
+  // file-backed PROT_READ|PROT_EXEC at the host level — writing into it is a
+  // real SIGSEGV/SIGBUS, confirmed via lldb). No copy was taken because none
+  // is needed: content can't diverge without an mprotect() neither dash nor
+  // toybox ever does, so there's nothing to restore here regardless of what
+  // the child did to its OWN view of this page.
+  (void)mi;
+}
+
+static void EmRestoreMem(struct Machine *m, struct EmMemSnap *ms) {
+  long i;
+  struct EmMemRestoreCtx cx;
+  memset(&cx, 0, sizeof(cx));
+  cx.ms = ms;
+  cx.seen = (unsigned char *)calloc(1, ms->n ? ms->n : 1);
+#ifdef MVL_NATIVE_DEBUG
+  fprintf(g_mvldbg, "[EmRestoreMem] enter, ms->n=%ld\n", ms->n);
+#endif
+  EmWalkLeaves(m->system, EmRestoreMemCb, &cx);
+#ifdef MVL_NATIVE_DEBUG
+  fprintf(g_mvldbg, "[EmRestoreMem] walk done, ndoom=%ld\n", cx.ndoom);
+#endif
+  // Unmap pages the child created.
+  for (i = 0; i < cx.ndoom; ++i) {
+    FreeVirtual(m->system, cx.doom[i], 4096);
+  }
+#ifdef MVL_NATIVE_DEBUG
+  fprintf(g_mvldbg, "[EmRestoreMem] doom freed, recreating unseen pages\n");
+#endif
+  // Re-create pages the child unmapped.
+  for (i = 0; i < ms->n; ++i) {
+    if (cx.seen[i]) continue;
+#ifdef MVL_NATIVE_DEBUG
+    fprintf(g_mvldbg, "[EmRestoreMem] recreate[%ld] virt=%llx has_copy=%d\n", i,
+            (unsigned long long)ms->p[i].virt, ms->p[i].copy != 0);
+#endif
+    u64 prot = ms->p[i].entry &
+               (PAGE_RW | PAGE_U | PAGE_XD | PAGE_G | PAGE_GROW | PAGE_FILE);
+    if (ReserveVirtual(m->system, ms->p[i].virt, 4096, prot | PAGE_RSRV, -1, 0,
+                       0, 0) == -1) {
+      EmDbgf("EmRestoreMem: cannot remap %" PRIx64, ms->p[i].virt);
+      continue;
+    }
+    if (ms->p[i].copy) {
+      CopyToUserWrite(m, ms->p[i].virt, ms->p[i].copy, 4096);
+    }
+  }
+#ifdef MVL_NATIVE_DEBUG
+  fprintf(g_mvldbg, "[EmRestoreMem] exit\n");
+#endif
+  m->system->brk = ms->brk;
+  memcpy(m->system->hands, ms->hands, sizeof(ms->hands));
+  free(cx.seen);
+  free(cx.doom);
+}
+
+static void EmFreeMemSnap(struct EmMemSnap *ms) {
+  long i;
+  for (i = 0; i < ms->n; ++i) free(ms->p[i].copy);
+  free(ms->p);
+  ms->p = 0;
+  ms->n = ms->c = 0;
+}
+
+// Guest fds live in [0, kMinBlinkFd); blink's own fds are >= kMinBlinkFd.
+struct EmFdSave {
+  int fildes;  // guest fd number (== host fd number in blink's model)
+  int oflags;  // blink Fd oflags, to rebuild the Fd struct
+  int slot;    // high host fd holding a dup of the original open file
+};
+
+// Snapshot the parent's fd table before running a vfork child by dup()ing each
+// open guest fd to a high slot (F_DUPFD_CLOEXEC min=kMinBlinkFd lands above the
+// guest range and skips blink's own fds), so the child's open/dup2/close for
+// redirections and pipes can be undone on resume. Returns the number of saved
+// entries.
+//
+// KNOWN LIMITATION (see the microvm-lite plan): dup2()ing fd 0/1/2 back on
+// restore rebinds those Emscripten fd slots to fresh stream objects that no
+// longer route through the worker's stdout/stderr TTY put_char capture, so in a
+// long-lived worker every command AFTER the first forking one loses its output.
+// Individual commands (fresh worker) are correct. Fixing this needs a cleaner
+// process/fd model — see the meta-discussion in the plan.
+static int EmSaveFds(struct Machine *m, struct EmFdSave *sv, int max) {
+  int n = 0;
+  struct Dll *e;
+  LOCK(&m->system->fds.lock);
+  for (e = dll_first(m->system->fds.list); e && n < max;
+       e = dll_next(m->system->fds.list, e)) {
+    struct Fd *fd = FD_CONTAINER(e);
+    if (fd->fildes < 0 || fd->fildes >= kMinBlinkFd) continue;  // skip vm fds
+    sv[n].fildes = fd->fildes;
+    sv[n].oflags = fd->oflags;
+    sv[n].slot = VfsFcntl(fd->fildes, F_DUPFD_CLOEXEC, kMinBlinkFd);
+    if (sv[n].slot == -1) {
+      LOGF("EmSaveFds: could not preserve fd %d (errno %d)", fd->fildes, errno);
+      continue;  // best effort: this fd won't be restorable, but don't abort
+    }
+    ++n;
+  }
+  UNLOCK(&m->system->fds.lock);
+  return n;
+}
+
+#ifdef __EMSCRIPTEN__
+// Real fork/vfork-backed background jobs (SCHEDULER-DESIGN.md, Phase 4):
+// builds a NEW, independent fd list for a scheduled fork child — reusing
+// EmSaveFds's dup-to-a-new-host-fd technique, but instead of stashing the
+// dups for a later restore (the old synchronous path's trick), installs
+// them as a genuinely separate `struct Dll` list mvl_dispatch.c swaps into
+// `m->system->fds.list` whenever this child is the one running (see
+// MvlSchedSpawnWithEntry's doc in mvl_dispatch.h for why fds need their own
+// list at all, unlike memory). Returns the new list (possibly NULL if the
+// parent had nothing open — a legitimate empty list, not a failure; the
+// caller passes `independent_fds=true` alongside it either way so mvl_
+// dispatch.c never confuses "empty" with "share the parent's").
+static struct Dll *EmDupFdsForChild(struct Machine *m) {
+  struct Fds tmp;
+  struct Dll *e;
+  InitFds(&tmp);
+  LOCK(&m->system->fds.lock);
+  for (e = dll_first(m->system->fds.list); e;
+       e = dll_next(m->system->fds.list, e)) {
+    struct Fd *fd = FD_CONTAINER(e);
+    struct Fd *fd2;
+    int dupfildes;
+    if (fd->fildes < 0 || fd->fildes >= kMinBlinkFd) continue;  // skip vm fds
+    if ((dupfildes = VfsFcntl(fd->realfd, F_DUPFD_CLOEXEC, kMinBlinkFd)) == -1) {
+      LOGF("EmDupFdsForChild: could not dup fd %d (errno %d)", fd->fildes, errno);
+      continue;  // best effort, matching EmSaveFds
+    }
+    // Guest-visible number MUST stay fd->fildes (real fork() preserves fd
+    // numbers in the child; the guest's own C state was memcpy'd mid-flight
+    // from the parent and still refers to it by that number) even though the
+    // actual duplicated resource lives at a different real host descriptor —
+    // see fds.h's realfd comment for why.
+    if (!(fd2 = ForkFd(&tmp, fd, fd->fildes, fd->oflags))) {
+      LOGF("EmDupFdsForChild: ForkFd failed for fd %d", fd->fildes);
+      VfsClose(dupfildes);
+    } else {
+      fd2->realfd = dupfildes;
+    }
+  }
+  UNLOCK(&m->system->fds.lock);
+  unassert(!pthread_mutex_destroy(&tmp.lock));  // only tmp.list is kept
+  return tmp.list;
+}
+#endif
+
+// Undo whatever the vfork child did to the shared fd table: tear down the
+// child's Fd list (freeing structs, closing the host fds it left in the guest
+// range), then restore each parent fd from its saved slot and rebuild the Fd
+// struct — leaving the table as it was at vfork() time.
+void EmSockOnClose(int fildes);  // defined in the M3 socket section below
+void EmDbgf(const char *fmt, ...);
+
+static void EmRestoreFds(struct Machine *m, struct EmFdSave *sv, int n) {
+  struct Dll *e, *e2;
+  int i, j;
+  LOCK(&m->system->fds.lock);
+  for (e = dll_first(m->system->fds.list); e; e = e2) {
+    struct Fd *fd = FD_CONTAINER(e);
+    e2 = dll_next(m->system->fds.list, e);
+    if (fd->fildes < 0 || fd->fildes >= kMinBlinkFd) continue;  // leave vm fds
+    dll_remove(&m->system->fds.list, e);
+    VfsClose(fd->fildes);
+    // A virtual socket the CHILD opened dies with the child's fd — clear its
+    // side-table entry so the fd number can't hijack an unrelated later fd.
+    // But if the parent owned this fd number too (it's in the saved set), the
+    // dup2 below restores the same open file, so any socket entry stays valid.
+    for (j = 0; j < n; ++j) {
+      if (sv[j].slot != -1 && sv[j].fildes == fd->fildes) break;
+    }
+    if (j == n) EmSockOnClose(fd->fildes);
+    FreeFd(fd);
+  }
+  for (i = 0; i < n; ++i) {
+    if (sv[i].slot == -1) continue;
+    VfsDup2(sv[i].slot, sv[i].fildes);  // restore the parent's open file
+    VfsClose(sv[i].slot);               // release the save slot
+    AddFd(&m->system->fds, sv[i].fildes, sv[i].oflags);
+  }
+  UNLOCK(&m->system->fds.lock);
+}
+
+// Real fork/vfork-backed background jobs (SCHEDULER-DESIGN.md, Phase 4).
+// The fiber driver for a scheduled fork child: mirrors MvlThreadEntry
+// (mvl_dispatch.c) but lives here because completing a fork child needs
+// EmStashChildStatus/g_em_children, which mvl_dispatch.c deliberately
+// doesn't know about (it's syscall.c-private, reused as-is from the old
+// synchronous path).
+static void EmForkChildEntry(struct Machine *m) {
+  int rc;
+  g_machine = m;
+  if (!(rc = sigsetjmp(m->onhalt, 1))) {
+    m->canhalt = true;
+    // Runs until HaltMachine(m, kMachineExitTrap) — either from
+    // SysExitGroup's em_vfork_child branch below (no execve: status
+    // already stashed directly before the halt), or from SysExecve's
+    // EXISTING vfork-child branch (execve'd: ran the new program to
+    // completion via a NESTED RunMachineUntilExit(m2) — safe under the
+    // scheduler because Actor()'s yield hook fires regardless of C call
+    // stack depth, so other fibers still get scheduled time while this
+    // fiber sits inside that nested call).
+    Actor(m);
+  }
+  (void)rc;
+  if (m->system->exited) {
+    // Came from SysExecve's vfork-child branch: it stashed the exec'd
+    // program's exit status in system->exitcode (a System-level field —
+    // safe here ONLY because there's no yield point between it setting
+    // this and us reading it right now, no Actor()/guest-instruction
+    // execution runs in between). Reset immediately so a sibling
+    // scheduled fork child sharing this System never misreads it.
+    EmStashChildStatus(m->tid, m->system->exitcode);
+    m->system->exited = false;
+  }
+  // Else: SysExitGroup's own em_vfork_child branch already stashed status
+  // directly before calling HaltMachine — nothing more to do here.
+  //
+  // Give the child's private guest stack back to the shared address space.
+  // Safe here: the guest is done executing (Actor() only returns via the
+  // siglongjmp above, and this function runs on the HOST fiber stack, not
+  // the guest stack being freed), and nothing can resume this Machine —
+  // MvlSchedThreadExitAndYield below unlinks the fiber for good.
+  //
+  // Without this, the ceiling was TOTAL forks ever run; with it, the
+  // ceiling is CONCURRENT forks, which for a shell pipeline is 2-3. The
+  // window is only zero bytes wide (see Fork()), so reuse is what makes
+  // long sessions possible at all.
+  if (m->em_forkstack) {
+    unassert(!FreeVirtual(m->system, m->em_forkstack, kStackSize));
+    m->em_forkstack = 0;
+  }
+  // Real fork() child: the kernel closes a dying process's fds, and that is
+  // what releases a pipe's last write end so the reader finally sees EOF
+  // (REAL-FORK.md). Do it BEFORE handing control away — after
+  // MvlSchedThreadExitAndYield this fiber never runs again.
+  if (m->em_own_system) {
+    // FreeMachine alone is the whole teardown: it dll_removes m from
+    // s->machines itself, and — because a real-fork child is always its
+    // System's only machine — takes the orphan branch and calls
+    // FreeSystem(s) too. Removing from the list or calling FreeSystem here
+    // as well is a DOUBLE free of the System (double DestroyFds, double
+    // free(s)); eight child exits of that corrupted the C heap enough to
+    // kill dash itself. EmCloseAllFds must still run first: FreeSystem's
+    // DestroyFds only frees the structs, never the dup'd host fds, and a
+    // closed write end is what gives the pipe reader its EOF.
+    EmCloseAllFds(m->system);
+    FreeMachine(m);  // orphan branch frees the System as well
+    g_machine = 0;   // this Machine is gone; don't leave a dangling pointer
+  }
+  MvlSchedThreadExitAndYield();
+}
+
+// Real fork(): build a child with its OWN System — private address space
+// AND its own fd table (REAL-FORK.md). This is what fork() actually means;
+// the shared-System path is for clone(CLONE_VM) (real threads, and musl's
+// posix_spawn trampoline), where sharing is correct.
+//
+// Returns 0 on failure, having freed whatever it had built.
+static struct Machine *EmForkPrivate(struct Machine *m) {
+  struct System *s2;
+  MvlForkLog("FORKENTER tid=%d\n", m->tid);
+  struct Machine *m2;
+  struct EmCopyAsCtx cx;
+  struct Dll *e;
+  if (!(s2 = NewSystem(m->system->mode))) {
+    MvlForkLog("FORKFAIL NewSystem\n");
+    return 0;
+  }
+  // NewMachine(s, 0) takes the machine's tid from system->pid, and NewSystem
+  // zeroes it — so allocate a genuinely unique pid here. Fork() returns this
+  // to the parent and EmStashChildStatus/SysWait4 key on it.
+  s2->pid = (m->system->next_tid++ & (kMaxThreadIds - 1)) + kMinThreadId;
+  s2->exec = m->system->exec;
+  memcpy(s2->rlim, m->system->rlim, sizeof(s2->rlim));
+  s2->automap = m->system->automap;
+  s2->brk = m->system->brk;
+  // NewSystem does NOT create the page-table root — only LoadProgram
+  // (loader.c) ever does. Without this, every walk below starts at cr3=0,
+  // and under wasm that's not a trap but a silent walk through the bottom
+  // of the linear memory: EmInstallSharedLeaf/ReserveVirtual "succeed"
+  // while corrupting the heap. Mirror LoadProgram's setup.
+  s2->cr0 = m->system->cr0;
+  s2->cr3 = AllocatePageTable(s2);
+  if (s2->cr3 == (u64)-1) {
+    MvlForkLog("FORKFAIL AllocatePageTable\n");
+    FreeSystem(s2);
+    return 0;
+  }
+  if (!(m2 = NewMachine(s2, 0))) {
+    MvlForkLog("FORKFAIL NewMachine\n");
+    FreeSystem(s2);
+    return 0;
+  }
+  memset(&cx, 0, sizeof(cx));
+  cx.dst = m2;
+  EmWalkLeaves(m->system, EmCopyAsCb, &cx);
+  MvlForkLog("COPYDONE npages=%ld nshared=%ld nbytes=%ld failed=%d\n",
+             cx.npages, cx.nshared, cx.nbytes, (int)cx.failed);
+  if (cx.failed) {
+    FreeMachine(m2);  // orphan branch frees s2 too — a second FreeSystem here
+                      // would be the same double free fixed in EmForkChildEntry
+    enomem();
+    return 0;
+  }
+  // Give the child the parent's register state. NewMachine's own parent
+  // branch would do this, but it asserts the parent shares the System, which
+  // is exactly what we're not doing — so replicate it, preserving the
+  // identity fields belonging to the NEW machine (system/tid) and the list
+  // node the System already links.
+  {
+    struct System *save_system = m2->system;
+    int save_tid = m2->tid;
+    struct Dll save_elem = m2->elem;
+    memcpy(m2, m, sizeof(*m2));
+    m2->system = save_system;
+    m2->tid = save_tid;
+    m2->elem = save_elem;
+    m2->mode = save_system->mode;
+    memset(&m2->path, 0, sizeof(m2->path));
+    memset(&m2->freelist, 0, sizeof(m2->freelist));
+    memset(&m2->pagelocks, 0, sizeof(m2->pagelocks));
+    ResetInstructionCache(m2);
+    m2->insyscall = false;
+    m2->nofault = false;
+    m2->sysdepth = 0;
+    m2->sigdepth = 0;
+    m2->signals = 0;
+    // Shared-System-era fields inherited by that memcpy that must NOT carry
+    // into a real-fork child. em_forkstack is the killer: it names a stack
+    // in the PARENT's address space, and EmForkChildEntry would hand the
+    // parent's memory back while the parent is still using it.
+    m2->em_forkstack = 0;
+    m2->em_vfork_child = false;  // real fork execve()s in place, correctly
+  }
+  // Copy the fd table. fork() gives the child its own table whose entries
+  // reference the SAME open file descriptions (shared file offsets) — which
+  // is precisely what dup() does. The guest-visible number is preserved;
+  // realfd carries the fresh host number, because every fiber in this
+  // process still shares one real host fd namespace (see fds.h).
+  LOCK(&m->system->fds.lock);
+  for (e = dll_first(m->system->fds.list); e;
+       e = dll_next(m->system->fds.list, e)) {
+    struct Fd *fd = FD_CONTAINER(e);
+    struct Fd *fd2;
+    int newreal;
+    if (fd->fildes < 0) continue;
+    if ((newreal = VfsFcntl(fd->realfd, F_DUPFD_CLOEXEC, kMinBlinkFd)) == -1) {
+      continue;  // best effort, matching EmDupFdsForChild
+    }
+    if ((fd2 = ForkFd(&s2->fds, fd, fd->fildes, fd->oflags))) {
+      fd2->realfd = newreal;
+    } else {
+      VfsClose(newreal);
+    }
+  }
+  UNLOCK(&m->system->fds.lock);
+  MvlForkLog("FORKOK child_tid=%d\n", m2->tid);
+  m2->em_own_system = true;  // its exit tears down s2 (EmForkChildEntry)
+  Put64(m2->ax, 0);  // the child's view of fork()'s return value
+  return m2;
+}
+
+static int Fork(struct Machine *m, u64 flags, u64 stack, u64 ctid) {
+  struct Machine *m2;
+  (void)flags;
+  (void)ctid;
+  // Real fork() — no CLONE_VM, no caller-supplied stack — means the child
+  // gets a PRIVATE address space and fd table (REAL-FORK.md). Everything
+  // below this branch is the clone(CLONE_VM) path: real threads, and musl's
+  // posix_spawn trampoline, which genuinely do want to share a System.
+  MvlForkLog("FORK flags=%llx stack=%llx -> %s\n", (unsigned long long)flags,
+             (unsigned long long)stack,
+             (!stack && !(flags & CLONE_VM_LINUX)) ? "PRIVATE" : "SHARED");
+  if (!stack && !(flags & CLONE_VM_LINUX)) {
+    if (!(m2 = EmForkPrivate(m))) return eagain();
+    if (MvlSchedSpawnOwnSystem(m2, EmForkChildEntry) != 0) {
+      EmCloseAllFds(m2->system);  // DestroyFds would leak the dup'd host fds
+      FreeMachine(m2);  // orphan branch frees the System too — no FreeSystem here
+      return eagain();
+    }
+    THR_LOGF("pid=%d Fork (wasm, private) -> child_pid=%d", m->system->pid,
+             m2->tid);
+    return m2->tid;
+  }
+  // Shares m->system with the parent — memory AND fd table (fds live on
+  // struct System, not struct Machine, so there is no way to share memory
+  // but NOT fds without splitting that struct; accepted as the same v1
+  // "share, don't isolate" simplification Phase 0-3 already made for
+  // memory — see SCHEDULER-DESIGN.md's Phase 4 notes). This REPLACES the
+  // old run-to-completion model (EmSaveMem/EmRestoreMem/EmSaveFds/
+  // EmRestoreFds/RunMachineUntilExit(m) reusing the SAME Machine for both
+  // parent and child) — a backgrounded child now genuinely runs
+  // concurrently with its parent instead of blocking it until done.
+  if (!(m2 = NewMachine(m->system, m))) {
+#ifdef MVL_NATIVE_DEBUG
+    fprintf(g_mvldbg, "[Fork] NewMachine FAILED\n");
+#endif
+    return eagain();
+  }
+  Put64(m2->ax, 0);  // child's view of fork()/vfork()/clone()'s return value
+  if (stack) {
+    // musl's posix_spawn (Rust's std::process::Command) calls
+    // clone(CLONE_VM|CLONE_VFORK, explicit_stack, ...) with its own
+    // trampoline stack — the guest already gave the child a stack that
+    // doesn't overlap the parent's, nothing more to do.
+    Put64(m2->sp, stack);
+  } else {
+    // Plain fork()/vfork() (stack==0, e.g. busybox hush NOMMU) — unlike
+    // the explicit-stack case above, NewMachine's memcpy left m2->sp equal
+    // to the PARENT's sp: both machines pointing at the SAME shared stack
+    // memory. That's correct for real vfork() (the parent is SUSPENDED
+    // until the child execve()s/exits, so only one of them ever actually
+    // runs) but wrong here — the child now runs CONCURRENTLY with the
+    // parent, so both would push/pop the identical stack addresses
+    // simultaneously, corrupting each other within microseconds
+    // (confirmed via lldb: FindPageTableEntry crash-looping on garbage
+    // addresses almost immediately, traced to exactly this). Give the
+    // child its own stack region and copy the parent's currently-live
+    // stack bytes into it, relocating sp by the same offset — sp/bp-
+    // relative frame access keeps working; an absolute pointer computed
+    // pre-fork to a stack local and dereferenced post-fork without an
+    // intervening execve() is a known, accepted gap (rare for the
+    // fork-then-quickly-execve pattern this targets, and real fork()'s
+    // full COW isolation is deliberately out of scope for v1 — see
+    // SCHEDULER-DESIGN.md).
+    i64 old_sp = Get64(m->sp);
+    i64 stack_bottom = kStackTop - kStackSize;
+    i64 new_stack;
+    // Copy only the LIVE stack (sp upward), not the whole 8 MB reservation.
+    // Everything below sp is dead by definition, and copying it cost an
+    // 8 MB malloc + 16 MB of copying per fork. That malloc is what actually
+    // capped a session once the guest stacks themselves were being reclaimed:
+    // measured 9 forks failing on it (host heap exhausted/fragmented by the
+    // per-fiber allocations mvl_dispatch.c defers freeing) while the guest
+    // address space still had room. A shell forking to run a pipeline stage
+    // has only a few KB live here.
+    //
+    // kRedZone: x86-64's ABI lets a leaf function use 128 bytes BELOW rsp
+    // without adjusting it, so that much genuinely-live data can sit under
+    // sp. Round up generously — this is cheap now that we're not copying
+    // the whole region.
+    enum { kRedZone = 4096 };
+    i64 live_from = old_sp - kRedZone;
+    i64 copy_bytes;
+    if (live_from < stack_bottom) live_from = stack_bottom;
+    if (old_sp < stack_bottom || old_sp > kStackTop) {
+      // sp isn't in the region we're about to duplicate (guest switched
+      // stacks itself). Copying a relocated window would be meaningless
+      // and silently wrong, so fall back to duplicating the whole region.
+      live_from = stack_bottom;
+    }
+    copy_bytes = kStackTop - live_from;
+    // ReserveVirtual(virt=0) does NOT mean "auto-place" outside the
+    // HasLinearMapping() case (confirmed via lldb: it returned literal
+    // address 0, silently colliding with low/reserved memory — the actual
+    // cause of the crash this comment replaces). SysMmap's own addr=0
+    // handling (syscall.c ~2108) shows the real pattern: resolve a free
+    // address via FindVirtual() first, THEN pass that to ReserveVirtual().
+    new_stack = FindVirtual(m->system, m->system->automap, kStackSize);
+    if (new_stack != -1) {
+      i64 newautomap = ROUNDUP(new_stack + kStackSize, FLAG_pagesize);
+      new_stack = ReserveVirtual(m->system, new_stack, kStackSize,
+                                 PAGE_FILE | PAGE_U | PAGE_RW, -1, 0, 0, 0);
+      if (new_stack != -1) {
+        m->system->automap =
+            newautomap < FLAG_automapend ? newautomap : FLAG_automapstart;
+      }
+    }
+    // Both failure paths below MUST fail the fork rather than continue.
+    // Continuing leaves m2->sp pointing at the PARENT's stack while the
+    // child runs concurrently, and the two then push/pop identical
+    // addresses — silent guest-memory corruption, not a crash. Observed as
+    // pipelines returning byte-count-correct GARBAGE, dash dying with
+    // "Out of space", and every later pipeline in that VM returning empty
+    // while the shell still responds. A failed fork() is recoverable and
+    // visible (dash prints "Cannot fork"); silent corruption is neither.
+    //
+    // This is reachable in normal use, not just under memory pressure: the
+    // wasm build has a 32-bit address space (blink's own GetBitsInAddress-
+    // Space returns 32 under __EMSCRIPTEN__), so ScaleAddress collapses
+    // FLAG_automapstart and FLAG_automapend onto the SAME address — the
+    // automap window is zero bytes wide, the assignment above always
+    // resets automap to the start, and these never-freed 8 MB stacks pile
+    // up from a fixed base until FindVirtual can't fit another one
+    // (~256 forks / ~128 pipelines). Reclaiming them is the real fix; this
+    // just makes hitting the ceiling honest.
+    if (new_stack == -1) {
+      LOGF("Fork: no room in the guest address space for the child's stack; "
+           "failing the fork instead of sharing the parent's stack");
+      FreeMachine(m2);
+      return eagain();
+    }
+    {
+      u8 *copybuf = (u8 *)malloc(copy_bytes);
+      if (!copybuf) {
+        LOGF("Fork: couldn't allocate the child's stack copy buffer");
+        unassert(!FreeVirtual(m->system, new_stack, kStackSize));
+        FreeMachine(m2);
+        return eagain();
+      }
+      // Same offset within the region for both, so sp/bp-relative frame
+      // access keeps working after the relocation.
+      CopyFromUser(m, copybuf, live_from, copy_bytes);
+      CopyToUser(m2, new_stack + (live_from - stack_bottom), copybuf,
+                 copy_bytes);
+      free(copybuf);
