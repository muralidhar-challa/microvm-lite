+// In-place execve(): no new Machine/System is created (unlike native Exec()).
+// This SAME Machine keeps its onhalt jmpbuf, fds, rlimits — only its virtual
+// memory is wiped and reloaded with the new program, and registers reset to
+// its entry point by LoadProgram. Since we never leave this call via longjmp,
+// returning normally is correct: the interpreter's next instruction fetch
+// naturally picks up m->ip at the new program's entry, continuing execution
+// as "the new program" with no unwind needed — whether this machine is
+// currently a vfork "child" (see Fork() above) or the top-level program
+// calling execve() directly.
+//
+// Known simplification vs. real execve(): custom (non-default, non-SIG_IGN)
+// signal handlers are reset via ResetSignalDispositions like native blink,
+// but blink's own SIG_IGN-preservation step (see Exec()'s old-branch in
+// blink.c, needed there because that path builds a fresh System) is not
+// replicated — it's a no-op here anyway since we never touch s->hands.
+static int SysExecve(struct Machine *m, i64 pa, i64 aa, i64 ea) {
+  char *prog, **argv, **envp;
+  sigset_t block;
+  if (!(prog = CopyStr(m, pa))) return -1;
+  if (!(argv = CopyStrList(m, aa))) return -1;
+  if (!(envp = CopyStrList(m, ea))) return -1;
+  LOCK(&m->system->exec_lock);
+  sigfillset(&block);
+  unassert(!pthread_sigmask(SIG_BLOCK, &block, &m->system->exec_sigmask));
+  if (!CanEmulateExecutable(m, &prog, &argv)) {
+    unassert(!pthread_sigmask(SIG_SETMASK, &m->system->exec_sigmask, 0));
+    UNLOCK(&m->system->exec_lock);
+    return enoexec();
+  }
+  // point of no return: prog/argv/envp are on the freelist, m->ip is about to
+  // be replaced by LoadProgram — nothing below may fail out to a caller that
+  // expects the OLD program's state.
+  //
+  // Native blink zeroes m->sysdepth here before flushing page locks (forces
+  // CollectPageLocks to release everything, regardless of nesting) — safe
+  // there because _Exit() immediately follows. We don't die: OpSyscall is
+  // still going to run `unassert(--m->sysdepth >= 0)` when THIS execve()
+  // syscall dispatch returns, and LoadProgram's own memory operations need
+  // sysdepth>0 (see RecordPageLock) — so restore it right after the flush.
+  {
+    int saved_sysdepth = m->sysdepth;
+    m->sysdepth = 0;
+    CollectPageLocks(m);
+    m->sysdepth = saved_sysdepth;
+  }
+  SYS_LOGF("execve(%s) [in-place, wasm]", prog);
+  SysCloseExec(m->system);
+  ResetTimerDispositions(m->system);
+  ResetSignalDispositions(m->system);
+  unassert(!FreeVirtual(m->system, -0x800000000000, 0x1000000000000));
+  LoadProgram(m, prog, prog, argv, envp, NULL);
+  unassert(!pthread_sigmask(SIG_SETMASK, &m->system->exec_sigmask, 0));
+  UNLOCK(&m->system->exec_lock);
+  return 0;  // never observed: the interpreter resumes at the new m->ip
+}
+
+// No host wait4()/waitpid() exists for our synthesized pids — Fork() (above)
+// already ran every child to completion and stashed its exit status.
+static int SysWait4(struct Machine *m, int pid, i64 opt_out_wstatus_addr,
+                    int options, i64 opt_out_rusage_addr) {
+  int rc, status;
+  u8 gwstatusb[4];
+  struct rusage_linux grusage;
+  if ((options = XlatWait(options)) == -1) return -1;
+  if ((opt_out_wstatus_addr && !IsValidMemory(m, opt_out_wstatus_addr,
+                                              sizeof(gwstatusb), PROT_WRITE)) ||
+      (opt_out_rusage_addr &&
+       !IsValidMemory(m, opt_out_rusage_addr, sizeof(grusage), PROT_WRITE))) {
+    return -1;
+  }
+  rc = EmReapChildStatus(pid, &status);
+  if (rc == -1) {
+    // Fork() runs children synchronously before returning, so a matching
+    // status should always be waiting unless the caller passes a pid we
+    // never spawned, or calls wait() twice for the same child.
+    return echild();
+  }
+  if (opt_out_wstatus_addr) {
+    Write32(gwstatusb, status);
+    CopyToUserWrite(m, opt_out_wstatus_addr, gwstatusb, sizeof(gwstatusb));
+  }
+  if (opt_out_rusage_addr) {
+    memset(&grusage, 0, sizeof(grusage));
+    CopyToUserWrite(m, opt_out_rusage_addr, &grusage, sizeof(grusage));
+  }
+  return rc;
+}
